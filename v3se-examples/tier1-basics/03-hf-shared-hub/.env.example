# 03-hf-shared-hub — .env.example
# Inherits the canonical contract from _shared/env/.env.template.

# Container paths — do not change
DATA_DIR=/data
RESULTS_DIR=/results
MODELS_DIR=/models

# Host paths (laptop). Leave blank for sibling defaults.
DATA_HOST=
RESULTS_HOST=
MODELS_HOST=

# C3SE cluster
CEPHYR_USER=
CEPHYR_PROJECT_PATH=
MIMER_GROUP_PATH=
MIMER_PROJECT_PATH=
ALVIS_ACCOUNT=
CEPHYR_TRANSFER_HOST=alvis2.c3se.chalmers.se
ALVIS_LOGIN_HOST=alvis2.c3se.chalmers.se

# HuggingFace — REQUIRED
# Pick a snapshot path that exists under C3SE's shared hub.
# Find available models:   ls /mimer/NOBACKUP/Datasets/LLM/huggingface/hub/
# Find available snapshots: ls /mimer/NOBACKUP/Datasets/LLM/huggingface/hub/models--<org>--<name>/snapshots/
HF_MODEL_SNAPSHOT=

# Torch device / dtype (optional — defaults in configs/config.toml)
HF_DEVICE=auto
HF_DTYPE=auto
HF_MAX_NEW_TOKENS=256
