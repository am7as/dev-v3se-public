Bootstrap: docker
From: ghcr.io/prefix-dev/pixi:0.36.0-noble

%environment
    export PIXI_HOME=/opt/pixi
    export PATH=/opt/pixi/bin:$PATH
    export LC_ALL=C.UTF-8
    export LANG=C.UTF-8

%post
    apt-get update
    apt-get install -y --no-install-recommends ca-certificates curl git openssh-client rsync tini
    rm -rf /var/lib/apt/lists/*

%runscript
    [ "$#" -eq 0 ] && exec bash
    exec "$@"

%help
    infer-api dev SIF. Bind code at run time:
        apptainer run --bind .:/workspace dev.sif pixi run infer --prompt "hi"
