# =============================================================================
# foundation — environment file
# Copy to .env and edit. Never commit .env (it's git-ignored).
# =============================================================================

# -----------------------------------------------------------------------------
# 1. CONTAINER PATHS (the Python code expects these; don't change)
# -----------------------------------------------------------------------------
DATA_DIR=/data
RESULTS_DIR=/results
MODELS_DIR=/models
WORKSPACE_DIR=/workspace
LOG_LEVEL=INFO

# -----------------------------------------------------------------------------
# 2. HOST BIND MOUNTS — where on your laptop the container paths map from
# -----------------------------------------------------------------------------
# Leave blank to use defaults (../data, ../results, ../models — siblings of
# this project). Override to point elsewhere. Forward slashes on Windows.
DATA_HOST=
RESULTS_HOST=
MODELS_HOST=

# -----------------------------------------------------------------------------
# 3. CEPHYR / ALVIS (used by _shared/scripts/sync-to-cephyr.sh)
# -----------------------------------------------------------------------------
CEPHYR_USER=
CEPHYR_PROJECT_PATH=
CEPHYR_TRANSFER_HOST=vera2.c3se.chalmers.se
MIMER_GROUP_PATH=
MIMER_PROJECT_PATH=
ALVIS_ACCOUNT=
ALVIS_LOGIN_HOST=alvis2.c3se.chalmers.se

# -----------------------------------------------------------------------------
# 4. NOTEBOOK PORTS (Docker Compose exposes these from the dev container)
# -----------------------------------------------------------------------------
JUPYTER_PORT=7888
