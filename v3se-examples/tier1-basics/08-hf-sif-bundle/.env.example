# 08-hf-sif-bundle — .env.example
# Inherits the canonical contract from _shared/env/.env.template.

# Container paths — do not change
DATA_DIR=/data
RESULTS_DIR=/results
MODELS_DIR=/models

# Host paths (laptop). Leave blank for sibling defaults.
DATA_HOST=
RESULTS_HOST=
MODELS_HOST=

# C3SE cluster
CEPHYR_USER=
CEPHYR_PROJECT_PATH=
MIMER_GROUP_PATH=
MIMER_PROJECT_PATH=
ALVIS_ACCOUNT=
CEPHYR_TRANSFER_HOST=vera2.c3se.chalmers.se
ALVIS_LOGIN_HOST=alvis2.c3se.chalmers.se

# HuggingFace — REQUIRED at build time
# The repo id to clone into the SIF.
HF_MODEL=google/gemma-2-2b-it

# Only needed for gated models (Llama family, gemma-2-*-it, etc.).
HF_TOKEN=

# At run time the model lives at /opt/model inside the SIF — don't change
# unless you also change apptainer/model.def.
MODEL_DIR=/opt/model

# Torch device / dtype (optional)
HF_DEVICE=auto
HF_DTYPE=auto
HF_MAX_NEW_TOKENS=256
