# =============================================================================
# Canonical .env template shared across all V3SE templates.
# Each template's own .env.example extends this with template-specific keys.
# =============================================================================

# -----------------------------------------------------------------------------
# 1. CONTAINER PATHS (do not change — the Python code expects these)
# -----------------------------------------------------------------------------
DATA_DIR=/data
RESULTS_DIR=/results
MODELS_DIR=/models
WORKSPACE_DIR=/workspace
LOG_LEVEL=INFO

# -----------------------------------------------------------------------------
# 2. HOST BIND MOUNTS — where on YOUR laptop the container paths map from
# -----------------------------------------------------------------------------
# Leave blank to use defaults (siblings of the project dir: ../data, ../results,
# ../models). Override if your folders live elsewhere. Forward slashes on Win.
DATA_HOST=
RESULTS_HOST=
MODELS_HOST=

# -----------------------------------------------------------------------------
# 3. HUGGINGFACE — cache MUST live in project storage, never $HOME on Alvis.
#    On laptop: /workspace/.hf-cache is fine.
#    On Alvis:  point HF_HOME at Mimer (/mimer/NOBACKUP/groups/<naiss-id>/<cid>/.hf-cache)
# -----------------------------------------------------------------------------
HF_HOME=/workspace/.hf-cache
TRANSFORMERS_CACHE=/workspace/.hf-cache
# Optional: a read-only snapshot path to a pre-downloaded model on Alvis.
# Example: HF_MODEL_SNAPSHOT=/mimer/NOBACKUP/Datasets/LLM/huggingface/hub/models--meta-llama--Llama-3.1-8B/snapshots/<hash>/
HF_MODEL_SNAPSHOT=

# -----------------------------------------------------------------------------
# 4. C3SE CLUSTER — set once, used by sync, sbatch, and port-forward scripts
# -----------------------------------------------------------------------------
# Your C3SE username.
CEPHYR_USER=

# Your Cephyr (small / code) project root.
# Example: /cephyr/users/<cid>/Alvis/my-project
CEPHYR_PROJECT_PATH=

# Your Mimer (large / data) project group root.
# Example: /mimer/NOBACKUP/groups/naiss2025-22-321
MIMER_GROUP_PATH=

# Your Mimer personal sub-path under the group (for results, checkpoints, caches).
# Example: /mimer/NOBACKUP/groups/naiss2025-22-321/<cid>/<project>
MIMER_PROJECT_PATH=

# Slurm project account (NAISS code) — every sbatch needs it in --account.
# Example: naiss2025-22-321 — leave as placeholder <PROJECT_ID> for committed sbatch files.
ALVIS_ACCOUNT=

# Cluster entry hosts (constants — don't usually change).
CEPHYR_TRANSFER_HOST=alvis2.c3se.chalmers.se
ALVIS_LOGIN_HOST=alvis2.c3se.chalmers.se

# -----------------------------------------------------------------------------
# 5. API KEYS (fill only the ones your template uses; leave blank otherwise)
# -----------------------------------------------------------------------------
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=
XAI_API_KEY=
HF_TOKEN=
WANDB_API_KEY=

# -----------------------------------------------------------------------------
# 6. RUNTIME OVERRIDES (normally blank)
# -----------------------------------------------------------------------------
# SMOKE_ONLY=1             # if your template supports a quick-smoke toggle
# DEBUG=1
