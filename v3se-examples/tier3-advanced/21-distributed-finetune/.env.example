DATA_DIR=/data
RESULTS_DIR=/results
MODELS_DIR=/models
WORKSPACE_DIR=/workspace
LOG_LEVEL=INFO

DATA_HOST=
RESULTS_HOST=
MODELS_HOST=

CEPHYR_USER=
CEPHYR_PROJECT_PATH=
CEPHYR_TRANSFER_HOST=vera2.c3se.chalmers.se
MIMER_GROUP_PATH=
MIMER_PROJECT_PATH=
ALVIS_ACCOUNT=
ALVIS_LOGIN_HOST=alvis2.c3se.chalmers.se

# Model + dataset
HF_MODEL=meta-llama/Llama-3.1-8B-Instruct
HF_MODEL_SNAPSHOT=
HF_HOME=/workspace/.hf-cache
TRANSFORMERS_CACHE=/workspace/.hf-cache
HF_TOKEN=

HF_DATASET=tatsu-lab/alpaca
HF_DATASET_SPLIT=train

# Training
NUM_EPOCHS=1
PER_DEVICE_BATCH=4
GRAD_ACCUM=8
LEARNING_RATE=2e-5
MAX_SEQ_LEN=2048
WARMUP_RATIO=0.03

# Parallelism strategy: ds_zero2 | ds_zero3 | fsdp
ACCELERATE_CONFIG=ds_zero2

# Checkpointing
SAVE_STEPS=500
SAVE_TOTAL_LIMIT=3

# Tracking
WANDB_API_KEY=
WANDB_PROJECT=v3se-dist-ft
WANDB_MODE=offline

JUPYTER_PORT=7888
