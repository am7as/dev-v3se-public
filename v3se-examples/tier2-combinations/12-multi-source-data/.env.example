DATA_DIR=/data
RESULTS_DIR=/results
MODELS_DIR=/models
WORKSPACE_DIR=/workspace
LOG_LEVEL=INFO

DATA_HOST=
RESULTS_HOST=
MODELS_HOST=

CEPHYR_USER=
CEPHYR_PROJECT_PATH=
CEPHYR_TRANSFER_HOST=vera2.c3se.chalmers.se
MIMER_GROUP_PATH=
MIMER_PROJECT_PATH=
ALVIS_ACCOUNT=
ALVIS_LOGIN_HOST=alvis2.c3se.chalmers.se

# Which source to read from (see configs/sources.yaml for options).
DATASET_SOURCE=local

# HuggingFace
HF_HOME=/workspace/.hf-cache
TRANSFORMERS_CACHE=/workspace/.hf-cache
HF_TOKEN=

# GCS — only used if DATASET_SOURCE=gcs
GCS_RCLONE_REMOTE=
GCS_RCLONE_PATH=

JUPYTER_PORT=7888
