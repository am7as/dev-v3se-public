DATA_DIR=/data
RESULTS_DIR=/results
MODELS_DIR=/models
WORKSPACE_DIR=/workspace
LOG_LEVEL=INFO

DATA_HOST=
RESULTS_HOST=
MODELS_HOST=

CEPHYR_USER=
CEPHYR_PROJECT_PATH=
CEPHYR_TRANSFER_HOST=vera2.c3se.chalmers.se
MIMER_GROUP_PATH=
MIMER_PROJECT_PATH=
ALVIS_ACCOUNT=
ALVIS_LOGIN_HOST=alvis2.c3se.chalmers.se

# ============================================================================
# Default provider (openai | claude_cli | vllm). Override with --provider.
# ============================================================================
DEFAULT_PROVIDER=openai

# ---------- openai provider ----------
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_BASE_URL=
#   For LM Studio / Ollama / local vLLM, point BASE_URL at the local port:
#     OPENAI_BASE_URL=http://host.docker.internal:1234/v1     (LM Studio)
#     OPENAI_BASE_URL=http://host.docker.internal:11434/v1    (Ollama)

# ---------- claude_cli provider ----------
# Path to the claude binary inside the container (set by Dockerfile/Apptainer).
CLAUDE_CLI_PATH=claude
CLAUDE_MODEL=claude-sonnet-4-6
# On laptop: bind-mount your host ~/.claude and ~/.claude.json (see
# docker-compose.yml, commented-out lines).
# On Alvis: sync your ~/.claude directory to Cephyr and bind it in sbatch.

# ---------- vllm provider ----------
# Set by vllm-server.sbatch — the client job reads these files:
VLLM_HOST_FILE=/results/vllm-host.txt
VLLM_PORT_FILE=/results/vllm-port.txt
# Or set directly for laptop tests:
VLLM_HOST=localhost
VLLM_PORT=8000
VLLM_MODEL=google/gemma-2-9b-it

JUPYTER_PORT=7888
