Bootstrap: docker
From: nvidia/cuda:12.6.3-cudnn-runtime-ubuntu22.04

%labels
    Name    git-model-bundle
    Author  v3se-template contributors

%post
    set -e
    apt-get update
    apt-get install -y --no-install-recommends \
        git git-lfs curl ca-certificates python3 python3-pip python3-venv
    git lfs install
    rm -rf /var/lib/apt/lists/*

    # Model repo URL + ref are injected as build-time args via `%arguments`
    # below. Override at build time:
    #     apptainer build --build-arg MODEL_REPO=... --build-arg MODEL_REF=...
    #
    # Fallback placeholders — replace in a real project.
    : "${MODEL_REPO:=https://example.invalid/<org>/<repo>.git}"
    : "${MODEL_REF:=main}"

    mkdir -p /opt/model
    cd /opt/model
    git clone --depth 1 --branch "${MODEL_REF}" "${MODEL_REPO}" .

    # If the repo uses git-lfs for weights, fetch them explicitly.
    git lfs pull || true

    # Install Python deps that ship with the repo.
    if [ -f requirements.txt ]; then
        python3 -m pip install --no-cache-dir -r requirements.txt
    elif [ -f pyproject.toml ]; then
        python3 -m pip install --no-cache-dir .
    fi

    # Shrink size: drop the .git directory post-clone (weights are now in files).
    rm -rf /opt/model/.git

%arguments
    MODEL_REPO=https://example.invalid/<org>/<repo>.git
    MODEL_REF=main

%environment
    export MODEL_DIR=/opt/model
    export PYTHONPATH=/opt/model:$PYTHONPATH

%runscript
    exec python3 -m infer_git_model "$@"

%help
    Git-cloned model baked into this SIF. Model lives at /opt/model.
    Set MODEL_REPO / MODEL_REF via --build-arg at build time.
    Example:
        apptainer build --build-arg MODEL_REPO=https://github.com/<org>/<repo>.git \
                        --build-arg MODEL_REF=v1.2 \
                        bundle.sif apptainer/bundle.def
