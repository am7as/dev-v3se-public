# 14-git-model-bundle — .env.example
# Inherits the canonical contract from _shared/env/.env.template.

# Container paths — do not change
DATA_DIR=/data
RESULTS_DIR=/results
MODELS_DIR=/models

# Host paths (laptop). Leave blank for sibling defaults.
DATA_HOST=
RESULTS_HOST=
MODELS_HOST=

# C3SE cluster
CEPHYR_USER=
CEPHYR_PROJECT_PATH=
MIMER_GROUP_PATH=
MIMER_PROJECT_PATH=
ALVIS_ACCOUNT=
CEPHYR_TRANSFER_HOST=vera2.c3se.chalmers.se
ALVIS_LOGIN_HOST=alvis2.c3se.chalmers.se

# Model bundle source — git URL + ref (branch / tag / commit)
MODEL_REPO=
MODEL_REF=main

# Where the baked model lives inside the built image (do not change)
MODEL_DIR=/opt/model

# Optional HF token if the model repo references HF-gated weights
HF_TOKEN=
