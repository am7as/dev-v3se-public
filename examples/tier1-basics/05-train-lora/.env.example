DATA_DIR=/data
RESULTS_DIR=/results
MODELS_DIR=/models
WORKSPACE_DIR=/workspace
LOG_LEVEL=INFO

DATA_HOST=
RESULTS_HOST=
MODELS_HOST=

# ----- C3SE / Alvis identity (5 primitives — set these once) -----
# Find your values:  ssh alvis 'whoami && projinfo'
CEPHYR_USER=
C3SE_PROJECT_ID=
NAISS_PROJECT_ID=
ALVIS_ACCOUNT=
PROJECT_NAME=

# Derived path roots + sibling dirs (don't usually edit; see _shared/env/.env.template)
CEPHYR_GROUP_ROOT=/cephyr/NOBACKUP/groups/${C3SE_PROJECT_ID}
MIMER_GROUP_ROOT=/mimer/NOBACKUP/groups/${NAISS_PROJECT_ID}
CEPHYR_USER_DIR=${CEPHYR_GROUP_ROOT}/users/${CEPHYR_USER}
CEPHYR_PROJECT_DIR=${CEPHYR_GROUP_ROOT}/projects/${PROJECT_NAME}
MIMER_USER_DIR=${MIMER_GROUP_ROOT}/users/${CEPHYR_USER}
MIMER_PROJECT_DIR=${MIMER_GROUP_ROOT}/projects/${PROJECT_NAME}

# Cluster entry hosts (constants — don't usually change)
CEPHYR_TRANSFER_HOST=alvis2.c3se.chalmers.se
ALVIS_LOGIN_HOST=alvis2.c3se.chalmers.se

# Base model (tiny by default for laptop runs; swap to something bigger on Alvis)
HF_MODEL=sshleifer/tiny-gpt2
HF_MODEL_SNAPSHOT=
HF_HOME=/workspace/.hf-cache
TRANSFORMERS_CACHE=/workspace/.hf-cache
HF_TOKEN=

# Dataset: empty = use the built-in 5-row in-memory sample.
# Otherwise an HF dataset id (text column named "text") or path to a JSONL.
HF_DATASET=

# LoRA hyperparameters
LORA_R=8
LORA_ALPHA=16
LORA_DROPOUT=0.05
NUM_EPOCHS=1
BATCH_SIZE=4
LEARNING_RATE=1e-4

# Optional: log to Weights & Biases
WANDB_API_KEY=
WANDB_PROJECT=lora
WANDB_MODE=offline

JUPYTER_PORT=7888
