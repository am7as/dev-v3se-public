# 09-hf-hub-streaming — .env.example
# Inherits the canonical contract from _shared/env/.env.template.

# Container paths — do not change
DATA_DIR=/data
RESULTS_DIR=/results
MODELS_DIR=/models

# Host paths (laptop). Leave blank for sibling defaults.
DATA_HOST=
RESULTS_HOST=
MODELS_HOST=

# C3SE cluster
# ----- C3SE / Alvis identity (5 primitives — set these once) -----
# Find your values:  ssh alvis 'whoami && projinfo'
CEPHYR_USER=
C3SE_PROJECT_ID=
NAISS_PROJECT_ID=
ALVIS_ACCOUNT=
PROJECT_NAME=

# Derived path roots + sibling dirs (don't usually edit; see _shared/env/.env.template)
CEPHYR_GROUP_ROOT=/cephyr/NOBACKUP/groups/${C3SE_PROJECT_ID}
MIMER_GROUP_ROOT=/mimer/NOBACKUP/groups/${NAISS_PROJECT_ID}
CEPHYR_USER_DIR=${CEPHYR_GROUP_ROOT}/users/${CEPHYR_USER}
CEPHYR_PROJECT_DIR=${CEPHYR_GROUP_ROOT}/projects/${PROJECT_NAME}
MIMER_USER_DIR=${MIMER_GROUP_ROOT}/users/${CEPHYR_USER}
MIMER_PROJECT_DIR=${MIMER_GROUP_ROOT}/projects/${PROJECT_NAME}

# Cluster entry hosts (constants — don't usually change)
CEPHYR_TRANSFER_HOST=alvis2.c3se.chalmers.se
ALVIS_LOGIN_HOST=alvis2.c3se.chalmers.se

# HuggingFace — REQUIRED
HF_MODEL=google/gemma-2-2b-it

# HF_HOME placement:
# - Laptop: /workspace/.hf-cache (inside Docker dev container) is fine
# - Cluster: MUST be on Mimer, NEVER on Cephyr or $HOME
#   Example: /mimer/NOBACKUP/groups/<naiss-id>/<cid>/.hf-cache
HF_HOME=/workspace/.hf-cache
TRANSFORMERS_CACHE=/workspace/.hf-cache

# Only needed for gated models (Llama family, gemma-2-*-it, etc.).
HF_TOKEN=

# Torch device / dtype (optional)
HF_DEVICE=auto
HF_DTYPE=auto
HF_MAX_NEW_TOKENS=256
