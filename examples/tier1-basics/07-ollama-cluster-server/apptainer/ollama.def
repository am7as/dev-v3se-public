Bootstrap: docker
From: ubuntu:24.04

%labels
    Name    ollama-server
    Author  template contributors

%post
    apt-get update
    apt-get install -y curl ca-certificates
    rm -rf /var/lib/apt/lists/*

    # Install Ollama. Installer places the binary at /usr/local/bin/ollama.
    # NOTE: pin a version in production; the latest channel can shift.
    curl -fsSL https://ollama.com/install.sh | sh

%environment
    # Model cache defaults — ALWAYS override on cluster to point at Mimer.
    export OLLAMA_MODELS="${OLLAMA_MODELS:-/tmp/ollama-models}"
    # Bind host:port; 0.0.0.0 is required so port-forwarding works.
    export OLLAMA_HOST="${OLLAMA_HOST:-0.0.0.0:11434}"

%runscript
    exec ollama "$@"

%help
    Apptainer image with the Ollama binary. Start the server with:
        apptainer run --nv ollama.sif serve
    Bind a Mimer path over the model cache:
        --bind /mimer/NOBACKUP/groups/<naiss-id>/<cid>/ollama:/tmp/ollama-models
    Then pull a model:
        apptainer exec ollama.sif ollama pull llama3.1:8b
