# 07-ollama-cluster-server — .env.example
# Inherits the canonical contract from _shared/env/.env.template.

# Container paths — do not change
DATA_DIR=/data
RESULTS_DIR=/results
MODELS_DIR=/models

# Host paths (laptop). Leave blank for sibling defaults.
DATA_HOST=
RESULTS_HOST=
MODELS_HOST=

# C3SE cluster
CEPHYR_USER=
CEPHYR_PROJECT_PATH=
MIMER_GROUP_PATH=
MIMER_PROJECT_PATH=
ALVIS_ACCOUNT=
CEPHYR_TRANSFER_HOST=alvis2.c3se.chalmers.se
ALVIS_LOGIN_HOST=alvis2.c3se.chalmers.se

# Ollama
# Model identifier as it appears in the Ollama library (e.g. llama3.1:8b, qwen2.5:14b).
OLLAMA_MODEL=llama3.1:8b

# Where Ollama stores downloaded weights. On Alvis, point at Mimer.
# Example: /mimer/NOBACKUP/groups/naiss2025-22-321/<cid>/ollama/models
OLLAMA_MODELS=

# Ollama server port (default 11434).
OLLAMA_PORT=11434

# OpenAI-compatible client — defaults used by client.py when not set
OPENAI_API_KEY=ollama
OPENAI_BASE_URL=
