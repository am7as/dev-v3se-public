# =============================================================================
# Canonical .env template shared across all templates.
# Each template's own .env.example extends this with template-specific keys.
# =============================================================================
#
# Design: identity primitives → derived path roots → derived sibling dirs.
# You set 5 identity values. Everything else composes from them. To rename
# the project on the cluster, change PROJECT_NAME — every path follows.
#
# =============================================================================

# -----------------------------------------------------------------------------
# 1. CONTAINER PATHS (do not change — the Python code expects these)
# -----------------------------------------------------------------------------
DATA_DIR=/data
RESULTS_DIR=/results
MODELS_DIR=/models
WORKSPACE_DIR=/workspace
LOG_LEVEL=INFO

# -----------------------------------------------------------------------------
# 2. HOST BIND MOUNTS — where on YOUR laptop the container paths map from
# -----------------------------------------------------------------------------
# Leave blank for sibling defaults (../data, ../results, ../models next to
# the project dir). Forward slashes on Windows.
DATA_HOST=
RESULTS_HOST=
MODELS_HOST=

# -----------------------------------------------------------------------------
# 3. HUGGINGFACE
#    Cache MUST live in project storage, never $HOME on Alvis.
#    Laptop:  /workspace/.hf-cache (default below).
#    Cluster: ${MIMER_USER_DIR}/.hf-cache  — sbatch files set this.
# -----------------------------------------------------------------------------
HF_HOME=/workspace/.hf-cache
TRANSFORMERS_CACHE=/workspace/.hf-cache
# Optional: read-only snapshot of a pre-downloaded model on Alvis.
# Example: HF_MODEL_SNAPSHOT=/mimer/NOBACKUP/Datasets/LLM/huggingface/hub/models--meta-llama--Llama-3.1-8B/snapshots/<hash>/
HF_MODEL_SNAPSHOT=

# -----------------------------------------------------------------------------
# 4. C3SE CLUSTER IDENTITY (5 primitives — set once)
# -----------------------------------------------------------------------------
# Find your values:  ssh alvis 'whoami && projinfo'
#
#   whoami         → your CID (Chalmers ID)            → CEPHYR_USER
#   projinfo lists Slurm projects:
#     c3se2025-… (Cephyr / small / code)               → C3SE_PROJECT_ID
#     naiss2025-… (Mimer / large / data)               → NAISS_PROJECT_ID
#     NAISS2026-… (the Slurm allocation)               → ALVIS_ACCOUNT
#   Your project's folder name on the cluster          → PROJECT_NAME

CEPHYR_USER=
C3SE_PROJECT_ID=
NAISS_PROJECT_ID=
ALVIS_ACCOUNT=
PROJECT_NAME=

# -----------------------------------------------------------------------------
# 5. DERIVED PATHS — composed from the 5 primitives above. Don't edit here
#    unless your group's filesystem layout differs from the C3SE convention.
# -----------------------------------------------------------------------------
# Group roots (filesystem entry points for everyone in the project):
CEPHYR_GROUP_ROOT=/cephyr/NOBACKUP/groups/${C3SE_PROJECT_ID}
MIMER_GROUP_ROOT=/mimer/NOBACKUP/groups/${NAISS_PROJECT_ID}

# Sibling dirs under each group root (C3SE convention: users/, shared/, projects/):
CEPHYR_USER_DIR=${CEPHYR_GROUP_ROOT}/users/${CEPHYR_USER}
CEPHYR_SHARED_DIR=${CEPHYR_GROUP_ROOT}/shared
CEPHYR_PROJECT_DIR=${CEPHYR_GROUP_ROOT}/projects/${PROJECT_NAME}
MIMER_USER_DIR=${MIMER_GROUP_ROOT}/users/${CEPHYR_USER}
MIMER_SHARED_DIR=${MIMER_GROUP_ROOT}/shared
MIMER_PROJECT_DIR=${MIMER_GROUP_ROOT}/projects/${PROJECT_NAME}

# Cluster entry hosts (constants — don't usually change).
CEPHYR_TRANSFER_HOST=alvis2.c3se.chalmers.se
ALVIS_LOGIN_HOST=alvis2.c3se.chalmers.se

# -----------------------------------------------------------------------------
# 6. API KEYS (fill only the ones your template uses; leave blank otherwise)
# -----------------------------------------------------------------------------
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=
XAI_API_KEY=
HF_TOKEN=
WANDB_API_KEY=

# -----------------------------------------------------------------------------
# 7. RUNTIME OVERRIDES (normally blank)
# -----------------------------------------------------------------------------
# SMOKE_ONLY=1             # if your template supports a quick-smoke toggle
# DEBUG=1
