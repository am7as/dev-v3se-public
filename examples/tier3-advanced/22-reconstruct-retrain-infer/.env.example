DATA_DIR=/data
RESULTS_DIR=/results
MODELS_DIR=/models
WORKSPACE_DIR=/workspace
LOG_LEVEL=INFO

DATA_HOST=
RESULTS_HOST=
MODELS_HOST=

CEPHYR_USER=
CEPHYR_PROJECT_PATH=
CEPHYR_TRANSFER_HOST=alvis2.c3se.chalmers.se
MIMER_GROUP_PATH=
MIMER_PROJECT_PATH=
ALVIS_ACCOUNT=
ALVIS_LOGIN_HOST=alvis2.c3se.chalmers.se

# Base model to reconstruct FROM
HF_MODEL=distilbert-base-uncased
HF_MODEL_SNAPSHOT=
HF_HOME=/workspace/.hf-cache
TRANSFORMERS_CACHE=/workspace/.hf-cache
HF_TOKEN=

# Dataset for retraining (expects text + label columns — see surgery example)
HF_DATASET=emotion
NUM_LABELS=6

# Training
NUM_EPOCHS=3
PER_DEVICE_BATCH=16
GRAD_ACCUM=1
LEARNING_RATE=2e-5
MAX_SEQ_LEN=128

# Surgery spec
SURGERY_CONFIG=configs/surgery.yaml

# Tracking
WANDB_API_KEY=
WANDB_PROJECT=reco
WANDB_MODE=offline

JUPYTER_PORT=7888
