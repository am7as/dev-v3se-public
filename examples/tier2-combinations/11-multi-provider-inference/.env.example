# =============================================================================
# 11-multi-provider-inference — env vars
# =============================================================================
# Each provider has its own labeled block below. Set keys/models for the
# provider(s) you'll actually use; leave the others blank.
#
# Pick the active provider via DEFAULT_PROVIDER (below) or `--provider X`
# at the command line. `pixi run infer --provider gemini --prompt "hi"`.
# =============================================================================

# ---------- container paths (don't change without good reason) ----------
DATA_DIR=/data
RESULTS_DIR=/results
MODELS_DIR=/models
WORKSPACE_DIR=/workspace
LOG_LEVEL=INFO

# ---------- host bind mounts (leave blank for sibling defaults) ----------
DATA_HOST=
RESULTS_HOST=
MODELS_HOST=

# ---------- C3SE / Alvis ----------
CEPHYR_USER=
CEPHYR_PROJECT_PATH=
CEPHYR_TRANSFER_HOST=alvis2.c3se.chalmers.se
MIMER_GROUP_PATH=
MIMER_PROJECT_PATH=
ALVIS_ACCOUNT=
ALVIS_LOGIN_HOST=alvis2.c3se.chalmers.se

# =============================================================================
# Active provider — pick one. Override at the CLI with `--provider X`.
#   Cloud APIs:        openai | gemini
#   CLI subscription:  claude_cli
#   Local servers:     lmstudio | ollama
#   Cluster server:    vllm
# =============================================================================
DEFAULT_PROVIDER=openai

# =============================================================================
# Cloud APIs
# =============================================================================

# ---------- openai (provider name: `openai`) ----------
# Standard OpenAI cloud API. Also accepts Azure OpenAI by setting
# OPENAI_BASE_URL to the Azure endpoint. For LM Studio / Ollama / vLLM,
# use the dedicated `lmstudio` / `ollama` / `vllm` providers below — don't
# repurpose this one.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_BASE_URL=

# ---------- gemini (provider name: `gemini`) ----------
# Google Gemini via the unified `google-genai` SDK. GEMINI_API_KEY is
# preferred; GOOGLE_API_KEY also honoured by the SDK as a fallback.
# Default is the current free-tier `gemini-2.5-flash`. Other options:
#   gemini-flash-latest   — alias auto-tracking current stable flash
#                            (future-proof, may shift behaviour over time)
#   gemini-2.5-pro        — paid; better reasoning, higher latency
#   gemini-2.0-flash      — older stable, still free
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
# Gemini 2.5 charges hidden "thinking" tokens for chain-of-thought even
# when not visible in the response. Set:
#   -1  → SDK default (unlimited; what you get if this is unset)
#    0  → disable thinking (cheapest; total tokens ≈ prompt + completion)
#   >0  → cap at N thinking tokens
GEMINI_THINKING_BUDGET=

# =============================================================================
# CLI-subscription
# =============================================================================

# ---------- claude_cli (provider name: `claude_cli`) ----------
# Drives the local `claude` binary (Claude CLI). Uses your Pro/Max
# subscription, not an API key. On laptop: bind-mount your host
# ~/.claude and ~/.claude.json (see docker-compose.yml). On Alvis: sync
# your ~/.claude to Cephyr and bind it in the sbatch.
CLAUDE_CLI_PATH=claude
CLAUDE_MODEL=claude-sonnet-4-6

# =============================================================================
# Local servers (laptop or compute-node) — OpenAI-compatible HTTP
# =============================================================================

# ---------- lmstudio (provider name: `lmstudio`) ----------
# LM Studio's HTTP server. Default URL works inside Docker on laptop
# when LM Studio runs on the host. On Alvis, use the
# `lmstudio-server.sbatch` pattern from `06-lmstudio-cluster-server`.
# LMSTUDIO_MODEL must match the loaded model id (see LM Studio →
# Models → Loaded → identifier column).
LMSTUDIO_BASE_URL=http://host.docker.internal:1234/v1
LMSTUDIO_MODEL=

# ---------- ollama (provider name: `ollama`) ----------
# Ollama's OpenAI-compatible endpoint. Default URL works inside Docker
# on laptop when `ollama serve` runs on the host. On Alvis, see
# `07-ollama-cluster-server`. OLLAMA_MODEL must be a pulled model
# (run `ollama pull llama3.2:3b` first → OLLAMA_MODEL=llama3.2:3b).
OLLAMA_BASE_URL=http://host.docker.internal:11434/v1
OLLAMA_MODEL=

# =============================================================================
# Cluster server (vLLM on Alvis A100) — set by sbatch handshake
# =============================================================================

# ---------- vllm (provider name: `vllm`) ----------
# `vllm-server.sbatch` writes vllm-host.txt + vllm-port.txt under
# $RESULTS_DIR; the client reads these. For laptop tests, set
# VLLM_HOST + VLLM_PORT directly.
VLLM_HOST_FILE=/results/vllm-host.txt
VLLM_PORT_FILE=/results/vllm-port.txt
VLLM_HOST=localhost
VLLM_PORT=8000
VLLM_MODEL=google/gemma-2-9b-it

# ---------- ports ----------
JUPYTER_PORT=7888
