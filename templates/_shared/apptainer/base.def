Bootstrap: docker
From: ghcr.io/prefix-dev/pixi:0.48.0-noble

%labels
    Author  template contributors
    Purpose Base image for all templates — Pixi + Python + cuda-capable

%environment
    export PIXI_HOME=/opt/pixi
    export PATH=/opt/pixi/bin:$PATH
    export LC_ALL=C.UTF-8
    export LANG=C.UTF-8
    # HuggingFace: never cache in home. Templates override to project storage.
    export HF_HOME=${HF_HOME:-/tmp/hf-cache}
    export TRANSFORMERS_CACHE=${TRANSFORMERS_CACHE:-/tmp/hf-cache}

%post
    set -eux
    # The prefix-dev/pixi image already has pixi on PATH and a usable shell.
    # Install the things every template needs regardless of Python deps:
    apt-get update
    apt-get install -y --no-install-recommends \
        ca-certificates curl git openssh-client rsync tini
    rm -rf /var/lib/apt/lists/*

    # Sanity
    pixi --version

%runscript
    exec "$@"

%help
    Shared base image. Every template's dev.def and app.def start from this
    (or from this + vLLM layers). You normally do not build base.sif by
    itself — the template-specific .def files extend it.

    Build:
        apptainer build base.sif _shared/apptainer/base.def

    Test:
        apptainer run --nv base.sif pixi --version
