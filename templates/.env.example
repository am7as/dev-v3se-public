# =============================================================================
# __PROJECT_SLUG__ — environment file
# Copy to .env and edit. Never commit .env (it's git-ignored).
# =============================================================================

# -----------------------------------------------------------------------------
# 1. CONTAINER PATHS (the Python code expects these; don't change)
# -----------------------------------------------------------------------------
DATA_DIR=/data
RESULTS_DIR=/results
MODELS_DIR=/models
WORKSPACE_DIR=/workspace
LOG_LEVEL=INFO

# -----------------------------------------------------------------------------
# 2. HOST BIND MOUNTS — where on your laptop the container paths map from
# -----------------------------------------------------------------------------
# Leave blank to use defaults (../data, ../results, ../models — siblings of
# this project). Override to point elsewhere. Forward slashes on Windows.
DATA_HOST=
RESULTS_HOST=
MODELS_HOST=

# -----------------------------------------------------------------------------
# 3. C3SE CLUSTER (Cephyr for code, Mimer for big data / weights / results)
# -----------------------------------------------------------------------------
# ----- C3SE / Alvis identity (5 primitives — set these once) -----
# Find your values:  ssh alvis 'whoami && projinfo'
CEPHYR_USER=
C3SE_PROJECT_ID=
NAISS_PROJECT_ID=
ALVIS_ACCOUNT=
PROJECT_NAME=

# Derived path roots + sibling dirs (don't usually edit; see _shared/env/.env.template)
CEPHYR_GROUP_ROOT=/cephyr/NOBACKUP/groups/${C3SE_PROJECT_ID}
MIMER_GROUP_ROOT=/mimer/NOBACKUP/groups/${NAISS_PROJECT_ID}
CEPHYR_USER_DIR=${CEPHYR_GROUP_ROOT}/users/${CEPHYR_USER}
CEPHYR_PROJECT_DIR=${CEPHYR_GROUP_ROOT}/projects/${PROJECT_NAME}
MIMER_USER_DIR=${MIMER_GROUP_ROOT}/users/${CEPHYR_USER}
MIMER_PROJECT_DIR=${MIMER_GROUP_ROOT}/projects/${PROJECT_NAME}

# Cluster entry hosts (constants — don't usually change)
CEPHYR_TRANSFER_HOST=alvis2.c3se.chalmers.se
ALVIS_LOGIN_HOST=alvis2.c3se.chalmers.se

# -----------------------------------------------------------------------------
# 4. NOTEBOOK PORTS (Docker Compose exposes these from the dev container)
# -----------------------------------------------------------------------------
JUPYTER_PORT=7888
